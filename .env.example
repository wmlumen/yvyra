# La demo estática no necesita variables.
# La versión full-stack debería definir, como mínimo:
DATABASE_URL=
AUTH_SECRET=
PUBLIC_APP_URL=http://localhost:3000
BASE_DOMAIN=localhost
TRUSTED_HOSTS=localhost,*.localhost
ANALYTICS_SALT=
SESSION_COOKIE_SECURE=false
# En producción, usar el dominio real y HTTPS:
# PUBLIC_APP_URL=https://enlacehub.com
# BASE_DOMAIN=enlacehub.com
# TRUSTED_HOSTS=enlacehub.com,*.enlacehub.com
# SESSION_COOKIE_SECURE=true

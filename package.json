{
  "name": "enlace-hub-demo",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "MVP local de un árbol de enlaces con subdominio por usuario, clasificados, miniweb, WhatsApp y analíticas.",
  "scripts": {
    "start": "cd server && npx prisma db push --accept-data-loss && node index.js",
    "dev": "python3 -m http.server 8080",
    "dev:server": "cd server && node index.js",
    "dev:all": "concurrently \"python3 -m http.server 8080\" \"cd server && node index.js\"",
    "postinstall": "cd server && npm install && npx prisma generate",
    "test": "node --test tests/*.test.mjs",
    "test:server": "cd server && npm test",
    "db:migrate": "cd server && npx prisma migrate dev",
    "db:push": "cd server && npx prisma db push",
    "db:seed:admin": "cd server && node scripts/seed-admin.js",
    "db:seed:showcase": "cd server && node scripts/seed-showcase.js",
    "db:verify:showcase": "cd server && node scripts/verify-showcase.js",
    "db:studio": "cd server && npx prisma studio",
    "lint": "npx eslint src/ server/ --ext .mjs,.js",
    "format": "npx prettier --write \"src/**/*.mjs\" \"server/**/*.js\"",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "cd server && tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "concurrently": "^9.1.2",
    "typescript": "^6.0.3"
  }
}

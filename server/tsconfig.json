{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@prisma/client": ["./node_modules/@prisma/client"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.mjs",
    "types.d.ts"
  ],
  "exclude": [
    "node_modules",
    "tests"
  ]
}
